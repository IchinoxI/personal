          { name: 'Aperturas laterales en máquina', target: 'Pecho' },
          { name: 'Hombros con mancuernas', target: 'Deltoides' },
          { name: 'Prensa de piernas', target: 'Cuádriceps / Glúteos' },
          { name: 'Músculos posteriores del muslo', target: 'Isquiotibiales' },
          { name: 'Parte frontal de las piernas', target: 'Cuádriceps' },
          { name: 'Abdominales', target: 'Core' }
        ]
      },
      6: { // Sábado
        name: 'Full Body',
        icon: '🔥',
        type: 'FULLBODY',
        exercises: [
          { name: 'Press de pecho con barra/máquina', target: 'Pecho' },
          { name: 'Remo en polea (espalda media)', target: 'Espalda' },
          { name: 'Aperturas pecho (máquina/mancuernas)', target: 'Pecho' },
          { name: 'Elevaciones de hombro', target: 'Deltoides' },
          { name: 'Prensa de piernas', target: 'Piernas' },
          { name: 'Curl de bíceps (barra/mancuernas)', target: 'Bíceps' },
          { name: 'Extensión de tríceps en polea', target: 'Tríceps' },
          { name: 'Abdominales controlados', target: 'Core' }
        ]
      }
    };

    const SERIES_REPS = [12, 10, 8, 8];
    const DAY_NAMES = ['', 'Lun', 'Mar', 'Mié', 'Jue', 'Vie', 'Sáb'];
    const DAY_FULL_NAMES = ['', 'Lunes', 'Martes', 'Miércoles', 'Jueves', 'Viernes', 'Sábado'];

    // ==================== ESTADO ====================
    let currentDay = new Date().getDay();
    if (currentDay === 0) currentDay = 1; // Domingo → Lunes
    if (currentDay > 6) currentDay = 1;

    let timerInterval = null;
    let timerSeconds = 0;
    let completedSeries = {};

    // ==================== INICIALIZACIÓN ====================
    function init() {
      loadProgress();
      checkDailyReset();
      renderDayNav();
      renderWorkout();
      updateCurrentDayName();
    }

    // ==================== NAVEGACIÓN DE DÍAS ====================
    function renderDayNav() {
      const nav = document.getElementById('dayNav');
      let html = '';
      
      for (let i = 1; i <= 6; i++) {
        const routine = ROUTINE[i];
        const isActive = currentDay === i;
        const isRest = routine.isRest;
        
        html += `
          <button class="day-tab ${isActive ? 'active' : ''} ${isRest ? 'rest-day' : ''}" 
                  onclick="changeDay(${i})">
            <span class="day-tab-short">${DAY_NAMES[i]}</span>
            <span class="day-tab-type">${routine.type}</span>
          </button>
        `;
      }
      
      nav.innerHTML = html;
    }

    function changeDay(day) {
      currentDay = day;
      renderDayNav();
      renderWorkout();
      updateCurrentDayName();
    }

    function updateCurrentDayName() {
      document.getElementById('currentDayName').textContent = DAY_FULL_NAMES[currentDay];
    }

    // ==================== RENDERIZADO DE RUTINA ====================
    function renderWorkout() {
      const workout = ROUTINE[currentDay];
      const content = document.getElementById('workoutContent');
      
      if (workout.isRest) {
        content.innerHTML = `
          <div class="rest-day-card fade-in">
            <div class="rest-day-icon">😴💤</div>
            <div class="rest-day-title">Día de Descanso</div>
            <div class="rest-day-message">
              Tu cuerpo necesita recuperarse para crecer más fuerte.<br>
              Descansa, hidrátate y come bien. 🥗💧
            </div>
          </div>
        `;
        document.querySelector('.timer-card').style.display = 'none';
        document.querySelector('.progress-card').style.display = 'none';
        return;
      }
      
      document.querySelector('.timer-card').style.display = 'block';
      document.querySelector('.progress-card').style.display = 'block';
      
      let html = `
        <div class="workout-title fade-in">
          <span class="workout-title-icon">${workout.icon}</span>
          <span>${workout.name}</span>
        </div>
      `;
      
      workout.exercises.forEach((exercise, exIdx) => {
        const completedCount = countCompletedSeries(exIdx);
        const isCompleted = completedCount === 4;
        
        html += `
          <div class="exercise-card fade-in ${isCompleted ? 'completed' : ''}" style="animation-delay: ${exIdx * 0.05}s">
            <div class="exercise-header">
              <div class="exercise-number">${exIdx + 1}</div>
              <div class="exercise-info">
                <div class="exercise-name">${exercise.name}</div>
                <div class="exercise-target">${exercise.target}</div>
              </div>
              <div class="exercise-check">✓</div>
            </div>
            <div class="series-grid">
              ${SERIES_REPS.map((reps, serieIdx) => {
                const key = `${currentDay}-${exIdx}-${serieIdx}`;
                const isDone = completedSeries[key] || false;
                return `
                  <div class="serie-item ${isDone ? 'done' : ''}" onclick="toggleSerie('${key}')">
                    <div class="serie-checkmark">✓</div>
                    <div class="serie-number">Serie ${serieIdx + 1}</div>
                    <div class="serie-reps">${reps}</div>
                    <div class="serie-label">reps</div>
                  </div>
                `;
              }).join('')}
            </div>
          </div>
        `;
      });
      
      content.innerHTML = html;
      updateProgress();
    }

    function countCompletedSeries(exIdx) {
      let count = 0;
      for (let i = 0; i < 4; i++) {
        if (completedSeries[`${currentDay}-${exIdx}-${i}`]) count++;
      }
      return count;
    }

    // ==================== TOGGLE SERIES ====================
    function toggleSerie(key) {
      completedSeries[key] = !completedSeries[key];
      saveProgress();
      renderWorkout();
      
      if (completedSeries[key]) {
        startTimer(90);
        
        // Vibración táctil
        if (navigator.vibrate) {
          navigator.vibrate(50);
        }
      }
      
      checkCompletion();
    }

    // ==================== CRONÓMETRO ====================
    function startTimer(seconds) {
      stopTimer();
      timerSeconds = seconds;
      updateTimerDisplay();
      document.getElementById('restOverlay').classList.add('active');
      document.getElementById('timerDisplay').classList.add('running');
      
      timerInterval = setInterval(() => {
        timerSeconds--;
        updateTimerDisplay();
        
        if (timerSeconds <= 0) {
          stopTimer();
          if (navigator.vibrate) {
            navigator.vibrate([200, 100, 200, 100, 200]);
          }
        }
      }, 1000);
    }

    function stopTimer() {
      if (timerInterval) {
        clearInterval(timerInterval);
        timerInterval = null;
      }
      document.getElementById('restOverlay').classList.remove('active');
      document.getElementById('timerDisplay').classList.remove('running');
      timerSeconds = 0;
      updateTimerDisplay();
    }

    function updateTimerDisplay() {
      const mins = Math.floor(timerSeconds / 60);
      const secs = timerSeconds % 60;
      const timeStr = `${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;
      document.getElementById('timerDisplay').textContent = timeStr;
      document.getElementById('restTime').textContent = timeStr;
    }

    // ==================== PROGRESO ====================
    function updateProgress() {
      const workout = ROUTINE[currentDay];
      if (workout.isRest) return;
      
      const totalSeries = workout.exercises.length * 4;
      let completed = 0;
      
      for (let i = 0; i < workout.exercises.length; i++) {
        for (let j = 0; j < 4; j++) {
          if (completedSeries[`${currentDay}-${i}-${j}`]) completed++;
        }
      }
      
      const percent = Math.round((completed / totalSeries) * 100);
      document.getElementById('progressBar').style.width = percent + '%';
      document.getElementById('progressValue').textContent = `${percent}% (${completed}/${totalSeries})`;
    }

    function checkCompletion() {
      const workout = ROUTINE[currentDay];
      if (workout.isRest) return;
      
      const totalSeries = workout.exercises.length * 4;
      let completed = 0;
      
      for (let i = 0; i < workout.exercises.length; i++) {
        for (let j = 0; j < 4; j++) {
          if (completedSeries[`${currentDay}-${i}-${j}`]) completed++;
        }
      }
      
      if (completed === totalSeries) {
        setTimeout(() => {
          document.getElementById('celebration').classList.add('active');
          if (navigator.vibrate) {
            navigator.vibrate([100, 50, 100, 50, 200]);
          }
        }, 300);
      }
    }

    function closeCelebration() {
      document.getElementById('celebration').classList.remove('active');
    }

    // ==================== PERSISTENCIA ====================
    function saveProgress() {
      localStorage.setItem('gymTrackerProgress', JSON.stringify(completedSeries));
      localStorage.setItem('gymTrackerDate', new Date().toDateString());
    }

    function loadProgress() {
      const saved = localStorage.getItem('gymTrackerProgress');
      if (saved) {
        completedSeries = JSON.parse(saved);
      }
    }

    function checkDailyReset() {
      const lastDate = localStorage.getItem('gymTrackerDate');
      const today = new Date().toDateString();
      
      if (lastDate !== today) {
        completedSeries = {};
        saveProgress();
      }
    }

    function resetDayProgress() {
      if (confirm('¿Reiniciar el progreso de hoy?')) {
        const workout = ROUTINE[currentDay];
        if (!workout.isRest) {
          for (let i = 0; i < workout.exercises.length; i++) {
            for (let j = 0; j < 4; j++) {
              delete completedSeries[`${currentDay}-${i}-${j}`];
            }
          }
          saveProgress();
          renderWorkout();
        }
      }
    }

    // ==================== INICIAR APP ====================
    init();
  </script>
</body>
</html>
